# ---- General Settings ----

# Specifies the log level for the project.
# Default: INFO
LOG_LEVEL=DEBUG

# Specifies the interval in seconds for polling the API and reloading the config.
# Default: 60
FP_CONFIG_RELOAD_INTERVAL_S=10

# ---- Threading & Performance ----

# Specifies the number of worker threads for processing frames.
# If not set, it defaults to the number of logical CPU cores minus 2 (with a minimum of 1).
FP_NUM_WORKER_THREADS=3

# Specifies the number of publisher threads for publishing frames.
# If not set, it defaults to the 4.
FP_PUBLISHER_THREADS=2

# ---- Horizontal Scaling (Multi-Instance) ----

# These variables control how streams are distributed across multiple instances.
# 
# FP_INSTANCE_SLOT: Unique ID for this instance (0, 1, 2...).
# In Docker Swarm, use {{.Task.Slot}} (which is 1-based).
FP_INSTANCE_SLOT=0
# 
# FP_TOTAL_INSTANCES: Total number of replicas.
FP_TOTAL_INSTANCES=1
# 
# FP_MAX_STREAMS: Hard limit on streams per instance (0 = unlimited).
FP_MAX_STREAMS=0
# 
# FP_STREAM_IDS: Comma-separated list of stream IDs to process exclusively.
FP_STREAM_IDS=


# ---- FFMPEG OPTIONS ----

# Set FFmpeg's logl level. Default value is ERROR ("AV_LOG_ERROR")
FFMPEG_LOG_LEVEL=AV_LOG_ERROR

# Force TCP or not, if not set UDP will be used as connection type
FP_RTSP_FORCE_TCP=1

# Timeout in seconds for establishing an RTSP stream connection
FP_RTSP_TCP_TIMEOUT_S=15

# Reconnect stream when it unexpectedly disconnects. EOF and end-of-streams are not counted here
FP_RETRY_STREAM_ON_ERROR=1

# Apply reconnect logic to apply even to streamed/non-seekable inputs
FP_RETRY_NON_LIVE_INPUT=1

# Treat EOF as an error and attempt reconnect the stream
FP_RETRY_EOF_STREAM=0

# Maximum time (in secs) to stop attmpeting to retry the stream at FFmpeg end.
FP_RECONNECT_DELAY_MAX_S=15

# Size (in bytes) for probing (method behind FFprobe) input to detect format
FP_PROBE_SIZE_B=32768

# Duration (in secs) for how long FFmpeg examines data to find streams.
FP_ANALYZE_DUR_S=5.0

# Timeout that applies to both read and write operations on the network socket.
FP_RW_TIMEOUT_S=5.0

# Allow low delay for streams to get frames via FFmpeg ?
FP_LOW_DELAY=0
FP_MAX_DELAY_US=50000

# Controls how many packets FFmpeg will queue between demuxer → codec threads
FP_THREAD_QUEUE_SIZE=128
FP_TCP_NODELAY=1

# ---- Network ----

# Timeout in seconds for all API calls made by the ConfigManager.
FP_API_TIMEOUT_S=15

# Number of times to retry connecting to a failed stream before giving up.
FP_STREAM_RECONNECT_ATTEMPTS=6

# Number of times a publisher thread will retry a failed command before discarding the batch.
FP_REDIS_RECONNECT_ATTEMPTS=5


# ---- Compilation ----

# Specifies the CMake build type. Affects compiler optimizations and debug symbols.
# Valid options: Release, Debug
# Default: Release
FP_BUILD_TYPE=Release


# ---- Redis Publisher Settings ----

# Hostname or IP address of the Redis server.
# If empty, the publisher will be disabled and batches will be dumped
FP_REDIS_HOST=redis

# Port number for the Redis server.
FP_REDIS_PORT=6379

# The BASE name of the Redis queues (LISTs) to push frame batches into.
FP_REDIS_QUEUE_BASE_NAME=fp_batches


# ---- API Endpoints ----

# ---- Debugging & Tools ----
FP_PUBLISHER_DRY_RUN=false
FP_PUBLISHER_DRY_RUN_DELAY_MS=10

# Disk Saving Tools
FP_SAVE_DECODED_FRAMES=false
FP_SAVE_PROCESSED_FRAMES=false
FP_SAVE_FRAME_INTERVAL=1
FP_SAVED_FRAMES_OUTPUT_DIR=/tmp/output

# ---- Memory & Backpressure ----

# If an unbounded queue's size exceeds this threshold, a warning will be logged.
# This does NOT prevent an OOM crash but makes the problem observable.
FP_QUEUE_WARNING_THRESHOLD=1000


